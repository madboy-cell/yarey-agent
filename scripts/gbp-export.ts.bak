/**
 * Google Business Profile - Automated CSV Export
 * 
 * This script uses Playwright to automate downloading the performance CSV
 * from business.google.com. First run requires manual login — subsequent runs
 * use saved session cookies.
 * 
 * Usage:
 *   npx tsx scripts/gbp-export.ts          # First run (opens browser for login)
 *   npx tsx scripts/gbp-export.ts --auto   # Subsequent runs (uses saved session)
 * 
 * After downloading, it auto-imports the CSV into the app via the API.
 */

import { chromium, BrowserContext } from "playwright"
import { existsSync, readFileSync } from "fs"
import { join } from "path"
import { FormData, File } from "undici"

const SESSION_PATH = join(__dirname, "..", ".gbp-session.json")
const DOWNLOAD_DIR = join(__dirname, "..", "tmp", "gbp-exports")
const APP_URL = process.env.APP_URL || "http://localhost:3000"

async function run() {
    const isAuto = process.argv.includes("--auto")
    const hasSession = existsSync(SESSION_PATH)

    console.log("🏪 Google Business Profile CSV Export")
    console.log(isAuto ? "   Mode: Automatic (using saved session)" : "   Mode: Interactive (manual login)")
    console.log("")

    // Launch browser
    const browser = await chromium.launch({
        headless: isAuto && hasSession, // Show browser for first login
    })

    let context: BrowserContext

    if (hasSession && isAuto) {
        // Restore saved session
        const sessionData = JSON.parse(readFileSync(SESSION_PATH, "utf-8"))
        context = await browser.newContext({
            storageState: sessionData,
            acceptDownloads: true,
        })
        console.log("✅ Loaded saved session")
    } else {
        context = await browser.newContext({ acceptDownloads: true })
    }

    const page = await context.newPage()

    try {
        // Navigate to Google Business Profile
        console.log("📱 Opening business.google.com...")
        await page.goto("https://business.google.com", { waitUntil: "networkidle" })

        // Check if we need to log in
        if (page.url().includes("accounts.google.com")) {
            if (isAuto && hasSession) {
                console.log("⚠️  Session expired. Run without --auto to re-login.")
                process.exit(1)
            }

            console.log("")
            console.log("🔐 Please log in to your Google account in the browser window.")
            console.log("   Use the account that owns the Yarey Business Profile.")
            console.log("   When you see the dashboard, press ENTER here...")
            console.log("")

            // Wait for user to log in
            await new Promise<void>((resolve) => {
                process.stdin.once("data", () => resolve())
            })
        }

        // Wait for the dashboard to load
        await page.waitForTimeout(3000)
        console.log("📊 Dashboard loaded:", page.url())

        // Save session for next time
        const storageState = await context.storageState()
        const { writeFileSync, mkdirSync } = await import("fs")
        writeFileSync(SESSION_PATH, JSON.stringify(storageState, null, 2))
        console.log("💾 Session saved for future use")

        // Navigate to Performance/Insights section
        // Look for Performance tab or similar
        const perfLink = page.locator('a[href*="performance"], a[href*="insights"], button:has-text("Performance")')
        if (await perfLink.count() > 0) {
            await perfLink.first().click()
            await page.waitForTimeout(3000)
            console.log("📈 Navigated to Performance")
        }

        // Look for download/export button
        const downloadBtn = page.locator('button:has-text("Download"), button:has-text("Export"), [aria-label*="download"], [aria-label*="export"]')

        if (await downloadBtn.count() > 0) {
            // Set up download handler
            const mkdirSync2 = (await import("fs")).mkdirSync
            mkdirSync2(DOWNLOAD_DIR, { recursive: true })

            const [download] = await Promise.all([
                page.waitForEvent("download"),
                downloadBtn.first().click(),
            ])

            const filePath = join(DOWNLOAD_DIR, download.suggestedFilename() || `gbp-export-${new Date().toISOString().slice(0, 10)}.csv`)
            await download.saveAs(filePath)
            console.log("📥 Downloaded:", filePath)

            // Auto-import to the app
            console.log("📤 Importing to app...")
            try {
                const csvContent = readFileSync(filePath)
                const formData = new FormData()
                const file = new File([csvContent], "gbp-export.csv", { type: "text/csv" })
                formData.append("file", file)

                const res = await fetch(`${APP_URL}/api/google/gbp/import`, {
                    method: "POST",
                    body: formData as any,
                })
                const json = await res.json()

                if (json.success) {
                    console.log("✅ Imported successfully!")
                    console.log(`   Keywords: ${json.data.searchQueries?.length || 0}`)
                    console.log(`   Impressions: ${json.data.metrics?.totalImpressions || 0}`)
                    console.log(`   Actions: ${json.data.metrics?.totalActions || 0}`)
                } else {
                    console.log("❌ Import failed:", json.error)
                }
            } catch (err: any) {
                console.log("⚠️  Auto-import failed (is the dev server running?):", err.message)
                console.log("   You can manually import the CSV from:", filePath)
            }
        } else {
            console.log("⚠️  Could not find download button. The page layout may have changed.")
            console.log("   Please download the CSV manually and import it in the Insights tab.")

            if (!isAuto) {
                console.log("   Press ENTER when done...")
                await new Promise<void>((resolve) => {
                    process.stdin.once("data", () => resolve())
                })
            }
        }
    } catch (err: any) {
        console.error("❌ Error:", err.message)
    } finally {
        await browser.close()
    }
}

run().catch(console.error)
